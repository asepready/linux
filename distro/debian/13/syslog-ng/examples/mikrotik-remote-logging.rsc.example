# Contoh RouterOS (Mikrotik): kirim log ke syslog server (syslog-ng, port 514).
# Ganti IP_LOG_SERVER. Jika action "remote-syslog" sudah ada, hapus dulu:
#   /system logging action remove [find name=remote-syslog]
# atau ubah IP lewat Winbox / System / Logging / Actions.

/system logging action add name=remote-syslog target=remote remote=IP_LOG_SERVER remote-port=514 bsd-syslog=yes

# Firewall: IP/port muncul saat aturan memakai log=yes atau action=log
/system logging add topics=firewall,info action=remote-syslog

# DNS: nama domain/query klien
/system logging add topics=dns,info action=remote-syslog

# Opsional: event sistem — hapus baris ini jika ingin log minimal
/system logging add topics=system,info action=remote-syslog

# Catatan:
# - Log firewall bisa sangat besar; batasi aturan log di firewall dan pertimbangkan rate.
# - Syslog ke port 514 biasanya tidak terenkripsi; untuk produksi pertimbangkan VPN atau segmentasi.
