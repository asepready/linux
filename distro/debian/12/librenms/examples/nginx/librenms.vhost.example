# Salin ke /etc/nginx/sites-available/librenms lalu aktifkan symlink ke sites-enabled.
# Dokumentasi resmi memakai nama sites-enabled/librenms.vhost — sesuaikan preferensi Anda.
# Rujukan: https://docs.librenms.org/Installation/Install-LibreNMS/#configure-web-server
#
# Setelah itu (seperti upstream Debian 12):
#   rm /etc/nginx/sites-enabled/default
#   systemctl reload nginx
#   systemctl restart php8.2-fpm

server {
    listen      80;
    server_name librenms.example.com;
    root        /opt/librenms/html;
    index       index.php;

    charset utf-8;
    gzip on;
    gzip_types text/css application/javascript text/javascript application/x-javascript image/svg+xml text/plain text/xsd text/xsl text/xml image/x-icon;
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }
    location ~ [^/]\.php(/|$) {
        fastcgi_pass unix:/run/php-fpm-librenms.sock;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        include fastcgi.conf;
    }
    location ~ /\.(?!well-known).* {
        deny all;
    }
}
